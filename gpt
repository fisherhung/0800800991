function openColorPopover(entryId,anchorEl){
  _colorTargetId=entryId;
  let pop=document.getElementById('color-popover');
  pop.innerHTML='';
  pop.style.display='flex';
  pop.style.flexWrap='wrap';
  pop.style.gap='6px';
