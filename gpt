.memo-card{padding:12px 14px;background:var(--card-bg);border:1px solid var(--border);border-radius:12px;transition:all .15s;}
.memo-card:hover{background:var(--card-hover);}
.memo-card.pinned{border-left:3px solid var(--amber);}
.manual-period-tag{display:inline-flex;align-items:center;padding:1px 7px;border-radius:99px;font-size:10px;font-weight:800;background:rgba(99,102,241,0.2);border:1px solid rgba(99,102,241,0.4);color:#a5b4fc;letter-spacing:.04em;}
.period-inline-btn{display:inline-flex;align-items:center;gap:3px;padding:1px 7px;border-radius:99px;font-size:10px;font-weight:800;cursor:pointer;border:1px solid rgba(99,102,241,0.4);background:rgba(99,102,241,0.12);color:#a5b4fc;transition:all .15s;user-select:none;position:relative;}
.period-inline-btn:hover{background:rgba(99,102,241,0.25);border-color:var(--accent);}
.period-inline-btn.auto{background:rgba(100,116,139,0.12);border-color:rgba(100,116,139,0.3);color:var(--text-muted);}
.period-inline-btn.auto:hover{background:rgba(99,102,241,0.12);border-color:rgba(99,102,241,0.4);color:#a5b4fc;}
.period-popover{position:absolute;bottom:calc(100% + 6px);left:0;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:5px;display:flex;gap:4px;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,0.3);}
.period-popover button{padding:4px 10px;border-radius:7px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);cursor:pointer;font-size:11px;font-weight:700;transition:all .15s;}
.period-popover button:hover,.period-popover button.active{background:var(--accent-dim);border-color:var(--accent-border);color:var(--accent);}
.mmdd-input{width:54px;padding:3px 7px;font-size:12px;font-weight:700;text-align:center;border-radius:7px;}
.help-section{padding:14px 16px;border-radius:14px;margin-bottom:2px;}
