<script>
// 🔥 Supabase Realtime 即時同步
function setupRealtime() {
  if (!window.supabase) return;

  const channel = supabase
    .channel('realtime-kml')
    .on(
      'postgres_changes',
      { event: '*', schema: 'public' },
      (payload) => {
        console.log('🔄 即時同步觸發:', payload);
        if (typeof fetchAllData === 'function') fetchAllData();
        if (typeof renderList === 'function') renderList();
        if (typeof renderKmlLayerList === 'function') renderKmlLayerList();
      }
    )
    .subscribe();

  console.log('✅ Realtime 已啟動');
}

// 等初始化完成後啟動
setTimeout(setupRealtime, 1500);
</script>


<script>
// ====== 🔥 Optimistic UI + Realtime Patch ======

// 保護性取得全域陣列
window.assets = window.assets || [];
window.kmlLayers = window.kmlLayers || [];

// ---- 地圖即時渲染 ----
function addAssetToMap(asset){
  try{
    if(asset.type === 'point' && typeof addPointLayer === 'function'){
      addPointLayer(asset);
    }
    if(asset.type === 'img' && typeof addImageLayer === 'function'){
      addImageLayer(asset);
    }
  }catch(e){ console.warn('addAssetToMap error', e); }
}

function addKmlToMap(layer){
  try{
    if(typeof drawKmlLayer === 'function'){
      drawKmlLayer(layer);
    }
  }catch(e){ console.warn('addKmlToMap error', e); }
}

// ---- 防重複 ----
function isAssetExist(id){
  return (window.assets || []).some(a => a.id === id);
}
function isKmlExist(id){
  return (window.kmlLayers || []).some(l => l.id === id);
}

// ---- 攔截 doUpload（不破壞原架構）----
if(typeof window.doUpload === 'function'){
  const _origUpload = window.doUpload;

  window.doUpload = async function(...args){
    const res = await _origUpload.apply(this, args);

    // 嘗試從最後一次 insert 拿資料（Supabase v2 常見）
    if(window._lastInsertData && Array.isArray(window._lastInsertData)){
      const newAsset = window._lastInsertData[0];
      if(newAsset && !isAssetExist(newAsset.id)){
        window.assets.push(newAsset);
        addAssetToMap(newAsset);
        if(typeof renderList === 'function') renderList();
      }
    }
    return res;
  }
}

// ---- 攔截 Supabase insert 回傳（通用方案）----
const _oldFrom = supabase.from.bind(supabase);
supabase.from = function(table){
  const q = _oldFrom(table);

  const _oldInsert = q.insert;
  q.insert = function(...args){
    const chain = _oldInsert.apply(this, args);

    const _oldSelect = chain.select;
    chain.select = function(...sargs){
      const sel = _oldSelect.apply(this, sargs);

      const _oldThen = sel.then;
      sel.then = function(resolve, reject){
        return _oldThen.call(this, (res)=>{
          if(res && res.data){
            window._lastInsertData = res.data;

            // 🔥 即時畫 asset
            if(table === 'assets'){
              const a = res.data[0];
              if(a && !isAssetExist(a.id)){
                window.assets.push(a);
                addAssetToMap(a);
                if(typeof renderList === 'function') renderList();
              }
            }

            // 🔥 即時畫 kml
            if(table === 'kml_layers'){
              const l = res.data[0];
              if(l && !isKmlExist(l.id)){
                window.kmlLayers.push(l);
                addKmlToMap(l);
                if(typeof renderKmlLayerList === 'function') renderKmlLayerList();
              }
            }
          }
          return resolve(res);
        }, reject);
      }
      return sel;
    }
    return chain;
  }
  return q;
}

// ---- Realtime 強化 ----
if(window.supabase){
  supabase
    .channel('ultra-realtime')
    .on('postgres_changes', { event: 'INSERT', schema: 'public' }, payload => {

      if(payload.table === 'assets'){
        const a = payload.new;
        if(a && !isAssetExist(a.id)){
          window.assets.push(a);
          addAssetToMap(a);
          if(typeof renderList === 'function') renderList();
        }
      }

      if(payload.table === 'kml_layers'){
        const l = payload.new;
        if(l && !isKmlExist(l.id)){
          window.kmlLayers.push(l);
          addKmlToMap(l);
          if(typeof renderKmlLayerList === 'function') renderKmlLayerList();
        }
      }

    })
    .subscribe();
}

console.log('🚀 Optimistic UI + Realtime Patch Loaded');
</script>


<script>
// ===== 🔥 FINAL FIX: Layer Registry + Delete Sync =====

// 全域 registry
window.layerMap = {};
window.kmlLayerMap = {};

// 包裝原本 addPointLayer / addImageLayer
function addAssetToMap(asset){
  let layer = null;

  if(asset.type === 'point' && typeof addPointLayer === 'function'){
    layer = addPointLayer(asset);
  }
  if(asset.type === 'img' && typeof addImageLayer === 'function'){
    layer = addImageLayer(asset);
  }

  if(layer){
    window.layerMap[asset.id] = layer;
  }
}

// KML
function addKmlToMap(layer){
  if(typeof drawKmlLayer === 'function'){
    const l = drawKmlLayer(layer);
    if(l){
      window.kmlLayerMap[layer.id] = l;
    }
  }
}

// 🔴 刪除 asset
function removeAssetFromMap(id){
  const layer = window.layerMap[id];
  if(layer && window.map){
    map.removeLayer(layer);
    delete window.layerMap[id];
  }
}

// 🔴 刪除 KML
function removeKmlFromMap(id){
  const l = window.kmlLayerMap[id];
  if(l && window.map){
    map.removeLayer(l);
    delete window.kmlLayerMap[id];
  }
}

// ---- 攔截 delete（Supabase）----
const _oldFrom2 = supabase.from.bind(supabase);
supabase.from = function(table){
  const q = _oldFrom2(table);

  const _oldDelete = q.delete;
  q.delete = function(...args){
    const chain = _oldDelete.apply(this, args);

    const _oldEq = chain.eq;
    chain.eq = function(col, val){
      const result = _oldEq.apply(this, arguments);

      const _oldThen = result.then;
      result.then = function(resolve, reject){
        return _oldThen.call(this, (res)=>{

          // 🔥 刪除同步 UI
          if(table === 'assets'){
            removeAssetFromMap(val);
            if(window.assets){
              window.assets = window.assets.filter(a => a.id !== val);
            }
            if(typeof renderList === 'function') renderList();
          }

          if(table === 'kml_layers'){
            removeKmlFromMap(val);
            if(window.kmlLayers){
              window.kmlLayers = window.kmlLayers.filter(l => l.id !== val);
            }
            if(typeof renderKmlLayerList === 'function') renderKmlLayerList();
          }

          return resolve(res);
        }, reject);
      }
      return result;
    }
    return chain;
  }
  return q;
}

// ---- Realtime DELETE 補強 ----
supabase
  .channel('delete-sync')
  .on('postgres_changes', { event: 'DELETE', schema: 'public' }, payload => {

    if(payload.table === 'assets'){
      removeAssetFromMap(payload.old.id);
    }

    if(payload.table === 'kml_layers'){
      removeKmlFromMap(payload.old.id);
    }

  })
  .subscribe();

console.log('🔥 FINAL FIX LOADED');
</script>

