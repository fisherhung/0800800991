// ── KML 核心操作 ──
// ══════════════════════════════════════════════
function _getKml(id){return kmlLayers.filter(function(x){return x.id===id;})[0]||null;}

function kmlHide(id){
  var en=_getKml(id);if(en)en.visible=false;
  var lines=kmlPolylines[id]||[];
  lines.forEach(function(pl){try{map.removeLayer(pl);}catch(e){}});
  kmlPolylines[id]=[];
}

function kmlShow(id){
  var en=_getKml(id);
  if(!en||!en._geoJSON)return;
  kmlHide(id);
  var lines=[];
  (en._geoJSON.features||[]).forEach(function(f){
    var geom=f.geometry;if(!geom)return;
    var rings=geom.type==='LineString'?[geom.coordinates]:geom.coordinates||[];
    rings.forEach(function(coords){
      var lls=coords.map(function(c){return[c[1],c[0]];});
      if(lls.length>1){
        var pl=L.polyline(lls,{color:en.color,weight:2.5,opacity:0.9});
        pl.bindTooltip(en.name,{className:'tt',sticky:true});
        pl.addTo(map);
        lines.push(pl);
      }
    });
  });
  kmlPolylines[id]=lines;
  en.visible=true;
}

// ── KML 圖層清單 ──
async function loadKmlLayers(){
  // 先清除地圖上所有 KML
  Object.keys(kmlPolylines).forEach(function(id){kmlHide(id);});
  kmlPolylines={};kmlLayers=[];
  try{
    const{data:rows,error}=await sb.from('kml_layers').select('*').order('created_at',{ascending:true});
    if(error)throw error;
    if(!rows||!rows.length){renderKmlList();updateKmlCountLabel();return;}
    let done=0;
    rows.forEach(function(row){
      const en={id:row.id,name:row.name,color:row.color||'#94a3b8',visible:false,
        geojson_url:row.geojson_url,storage_path:row.storage_path,_geoJSON:null};
      kmlLayers.push(en);
      if(row.geojson_url){
        fetch(row.geojson_url).then(function(res){return res.json();}).then(function(gj){
          en._geoJSON=gj;
        }).catch(function(e){console.warn('KML fetch err:',e);}).finally(function(){
          done++;if(done===rows.length){renderKmlList();updateKmlCountLabel();}
        });
      }else{done++;if(done===rows.length){renderKmlList();updateKmlCountLabel();}}
    });
  }catch(e){console.error('loadKmlLayers error:',e);renderKmlList();updateKmlCountLabel();}
}

function updateKmlCountLabel(){
  const el=document.getElementById('kml-count-label');
  if(el)el.textContent=kmlLayers.length+' 個圖層';
}

// ── KML 列表渲染 ──
function renderKmlList(){
  const el=document.getElementById('kml-layer-list');
  if(!el)return;
  el.innerHTML='';
  updateKmlCountLabel();
  if(!kmlLayers.length){
    el.innerHTML='<div style="font-size:11px;color:var(--text-muted);text-align:center;padding:8px 0;">尚無 KML 圖層</div>';
    return;
  }
  kmlLayers.forEach(function(entry){
    const card=document.createElement('div');card.className='kml-layer-card';
    // 顏色點
    const dot=document.createElement('div');dot.className='kml-color-dot';
    dot.style.background=entry.color;dot.title='點擊換色';
    dot.onclick=function(e){e.stopPropagation();openColorPopover(entry.id,dot);};
    // 名稱
    const nameEl=document.createElement('span');nameEl.className='kml-layer-name';
    nameEl.textContent=entry.name;nameEl.title='雙擊改名';
    nameEl.ondblclick=function(){
      const inp=document.createElement('input');inp.type='text';
      inp.style.cssText='flex:1;font-size:12px;font-weight:600;padding:2px 6px;border-radius:6px;min-width:0;background:var(--input-bg);border:1px solid var(--accent-border);color:var(--text);outline:none;';
      inp.value=nameEl.textContent;nameEl.replaceWith(inp);inp.focus();inp.select();
      function commit(){
        const n=(inp.value||'').trim()||entry.name;
        sb.from('kml_layers').update({name:n}).eq('id',entry.id).then(function(){
          const en=_getKml(entry.id);if(en)en.name=n;
          renderKmlList();toast('已改名','success');
        }).catch(function(e){toast('改名失敗：'+e.message,'error');});
      }
      inp.onblur=commit;
      inp.onkeydown=function(ev){
        if(ev.key==='Enter')inp.blur();
        if(ev.key==='Escape'){inp.value=entry.name;inp.blur();}
      };
    };
    // 眼睛按鈕
    const isOn=!!(kmlPolylines[entry.id]&&kmlPolylines[entry.id].length>0);
    const eyeBtn=document.createElement('button');
    eyeBtn.className='kml-eye-btn'+(isOn?' on':'');
    eyeBtn.textContent=isOn?'👁':'🙈';
    eyeBtn.title=isOn?'點擊隱藏':'點擊顯示';
    eyeBtn.onclick=function(ev){
      ev.stopPropagation();
      const currently=!!(kmlPolylines[entry.id]&&kmlPolylines[entry.id].length>0);
      if(currently){
        kmlHide(entry.id);
        eyeBtn.textContent='🙈';eyeBtn.title='點擊顯示';eyeBtn.classList.remove('on');
      }else{
        const en=_getKml(entry.id);
        if(!en)return;
        if(!en._geoJSON){
          if(!en.geojson_url)return;
          eyeBtn.textContent='⏳';eyeBtn.disabled=true;
          fetch(en.geojson_url).then(function(r){return r.json();}).then(function(gj){
            en._geoJSON=gj;kmlShow(entry.id);
            eyeBtn.textContent='👁';eyeBtn.title='點擊隱藏';eyeBtn.classList.add('on');eyeBtn.disabled=false;
          }).catch(function(){eyeBtn.textContent='❌';eyeBtn.disabled=false;toast('載入失敗','error');});
          return;
        }
        kmlShow(entry.id);
        eyeBtn.textContent='👁';eyeBtn.title='點擊隱藏';eyeBtn.classList.add('on');
      }
      sb.from('kml_layers').update({visible:!currently}).eq('id',entry.id).catch(function(){});
    };
    // 刪除
    const delBtn=document.createElement('button');delBtn.className='kml-del-btn';delBtn.textContent='🗑️';delBtn.title='刪除';
    delBtn.onclick=function(ev){
      ev.stopPropagation();
      if(!confirm('確定刪除此 KML 圖層？'))return;
      kmlHide(entry.id);delete kmlPolylines[entry.id];
      const en=_getKml(entry.id);
      if(en&&en.storage_path){
        sb.storage.from('kml-files').remove([en.storage_path]).catch(function(){});
      }
      sb.from('kml_layers').delete().eq('id',entry.id).then(function(){
        kmlLayers=kmlLayers.filter(function(x){return x.id!==entry.id;});
        renderKmlList();updateKmlCountLabel();toast('已刪除','info');
      }).catch(function(e){toast('刪除失敗：'+e.message,'error');});
    };
    card.append(dot,nameEl,eyeBtn,delBtn);el.appendChild(card);
  });
}

