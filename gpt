  else{let cnt=0;const fl=setInterval(()=>{cnt++;a.visual.eachLayer(l=>{if(l.setStyle)l.setStyle({radius:cnt%2===0?6:10});});if(cnt>=6){clearInterval(fl);a.visual.eachLayer(l=>{if(l.setStyle)l.setStyle({radius:6});});}},180);}
