<script>
// ===== 🔥 強制修正：自動抓 Leaflet layer（不用改你原本 function） =====

// 攔截 Leaflet addTo，自動記錄最後一個 layer
(function(){
  const oldAddTo = L.Layer.prototype.addTo;

  L.Layer.prototype.addTo = function(map){
    const result = oldAddTo.call(this, map);
    window.__lastLayer = this; // ⭐記錄最後畫的 layer
    return result;
  };
})();

// ===== 強制接管 asset 畫圖 =====
function addAssetToMap(asset){
  window.__lastLayer = null;

  if(asset.type === 'point' && typeof addPointLayer === 'function'){
    addPointLayer(asset);
  }

  if(asset.type === 'img' && typeof addImageLayer === 'function'){
    addImageLayer(asset);
  }

  const layer = window.__lastLayer;

  if(layer){
    window.layerMap = window.layerMap || {};
    window.layerMap[asset.id] = layer;
    console.log('✅ 抓到 layer:', asset.id);
  }else{
    console.warn('❌ 沒抓到 layer:', asset);
  }
}

// ===== KML 同樣處理 =====
function addKmlToMap(layerData){
  window.__lastLayer = null;

  if(typeof drawKmlLayer === 'function'){
    drawKmlLayer(layerData);
  }

  const layer = window.__lastLayer;

  if(layer){
    window.kmlLayerMap = window.kmlLayerMap || {};
