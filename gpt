    .on('postgres_changes',{event:'*',schema:'public',table:'memo_comments'},async()=>{const{data:cData}=await sb.from('memo_comments').select('*').order('created_at',{ascending:true});memoComments={};(cData||[]).forEach(c=>{if(!memoComments[c.memo_id])memoComments[c.memo_id]=[];memoComments[c.memo_id].push(c);});if(memoOpen)renderMemos();if(activeId)renderPanelMemos(activeId);})
