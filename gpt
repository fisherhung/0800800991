.batch-prog-track{height:6px;background:var(--border);border-radius:99px;overflow:hidden;margin-top:6px;}
.batch-prog-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,#6366f1,#10b981);transition:width .3s;}
#panel-memo-section{margin-top:14px;border-top:1px solid var(--border);padding-top:12px;}
#panel-memo-section .pm-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
#panel-memo-section .pm-title{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:800;color:var(--text-muted);letter-spacing:.1em;}
#panel-memo-section .pm-add-btn{display:flex;align-items:center;gap:4px;padding:3px 9px;border-radius:7px;border:1px solid var(--accent-border);background:var(--accent-dim);color:var(--accent);cursor:pointer;font-size:11px;font-weight:700;transition:all .15s;}
