<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
:root{
  --bg:#0a0f1e;--surface:#111827;--surface2:#1f2937;--border:rgba(255,255,255,0.07);
  --text:#f1f5f9;--text-muted:#64748b;--text-sub:#94a3b8;
  --card-bg:rgba(255,255,255,0.02);--card-hover:rgba(255,255,255,0.05);
  --input-bg:rgba(255,255,255,0.04);--header-bg:rgba(10,15,30,0.97);
  --sidebar-bg:rgba(17,24,39,0.98);--accent:#6366f1;--accent2:#8b5cf6;
  --accent-dim:rgba(99,102,241,0.12);--accent-border:rgba(99,102,241,0.25);
  --green:#10b981;--amber:#f59e0b;--sidebar-w:400px;--header-h:76px;
  --transition:background 0.3s,color 0.3s,border-color 0.3s;
}
[data-theme="light"]{
  --bg:#f1f5f9;--surface:#ffffff;--surface2:#f8fafc;--border:rgba(0,0,0,0.08);
  --text:#0f172a;--text-muted:#94a3b8;--text-sub:#64748b;
  --card-bg:rgba(255,255,255,0.8);--card-hover:rgba(99,102,241,0.04);
  --input-bg:rgba(0,0,0,0.03);--header-bg:rgba(255,255,255,0.97);
  --sidebar-bg:rgba(255,255,255,0.98);
  --accent-dim:rgba(99,102,241,0.08);--accent-border:rgba(99,102,241,0.2);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Inter','Noto Sans TC',sans-serif;background:var(--bg);color:var(--text);overflow:hidden;height:100vh;display:flex;flex-direction:column;transition:var(--transition);}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-thumb{background:rgba(128,128,128,0.2);border-radius:99px;}
#loading{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.spinner{width:44px;height:44px;border:3px solid rgba(99,102,241,0.15);border-top-color:#6366f1;border-radius:50%;animation:spin .8s linear infinite;margin-bottom:18px;}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes live-pulse{0%{box-shadow:0 0 0 0 rgba(16,185,129,0.7);opacity:1;}60%{box-shadow:0 0 0 6px rgba(16,185,129,0);opacity:0.75;}100%{box-shadow:0 0 0 0 rgba(16,185,129,0);opacity:1;}}
@keyframes memo-badge-pop{0%{transform:scale(0.5);opacity:0}100%{transform:scale(1);opacity:1}}
@keyframes memo-row-in{0%{opacity:0;transform:translateY(4px)}100%{opacity:1;transform:translateY(0)}}
#db-dot.live{animation:live-pulse 1.6s ease-out infinite;}
header{height:var(--header-h);background:var(--header-bg);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:2000;flex-shrink:0;transition:var(--transition);}
.sidebar{width:var(--sidebar-w);flex-shrink:0;background:var(--sidebar-bg);backdrop-filter:blur(20px);border-right:1px solid var(--border);display:flex;flex-direction:column;height:100%;transition:margin .4s cubic-bezier(.16,1,.3,1),var(--transition);}
.sidebar.collapsed{margin-left:calc(-1 * var(--sidebar-w));}
.tt{background:var(--surface)!important;color:var(--text)!important;border:1px solid var(--border)!important;border-radius:8px;padding:5px 12px;font-weight:700;font-size:12px;box-shadow:0 4px 20px rgba(0,0,0,0.2);}
.chip{cursor:pointer;white-space:nowrap;font-weight:600;font-size:12px;padding:4px 12px;border-radius:99px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);transition:all .2s;}
.chip:hover{border-color:var(--accent-border);color:var(--accent);}
.chip.active{background:var(--accent-dim);border-color:var(--accent-border);color:var(--accent);}
.op-chip{cursor:pointer;white-space:nowrap;font-weight:600;font-size:12px;padding:3px 10px;border-radius:99px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);transition:all .2s;}
.op-chip:hover{border-color:var(--accent-border);color:var(--accent);}
.op-chip.active{background:var(--accent-dim);border-color:var(--accent-border);color:var(--accent);}
.period-chip{cursor:pointer;white-space:nowrap;font-weight:700;font-size:12px;padding:4px 13px;border-radius:99px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);transition:all .2s;}
.period-chip:hover{border-color:var(--accent-border);color:var(--accent);}
.period-chip.active{background:var(--accent-dim);border-color:var(--accent-border);color:var(--accent);}
.tab{cursor:pointer;padding:10px 0;font-weight:700;font-size:13px;border-bottom:2px solid transparent;transition:all .2s;color:var(--text-muted);text-align:center;flex:1;}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.btn-accent{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border:none;cursor:pointer;font-weight:700;transition:all .2s;border-radius:12px;}
.btn-accent:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 8px 25px rgba(99,102,241,0.3);}
.btn-green{background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.25);color:#10b981;border-radius:12px;cursor:pointer;font-weight:700;transition:all .2s;}
.btn-green:hover{background:rgba(16,185,129,0.2);}
.btn-ghost{background:var(--input-bg);border:1px solid var(--border);color:var(--text-muted);border-radius:10px;cursor:pointer;font-weight:600;transition:all .2s;}
.btn-ghost:hover{background:var(--card-hover);color:var(--text);}
.btn-locked{background:var(--input-bg)!important;border:1px solid var(--border)!important;color:var(--text-muted)!important;opacity:.4!important;cursor:not-allowed!important;transform:none!important;box-shadow:none!important;}
.asset-card{display:flex;align-items:center;gap:10px;padding:9px 11px;border-radius:10px;border:1px solid var(--border);background:var(--card-bg);transition:all .15s;}
.asset-card:hover{background:var(--card-hover);border-color:var(--accent-border);}
.asset-card.active{background:var(--accent-dim);border-color:var(--accent-border);}
@keyframes card-flash{0%,100%{background:var(--accent-dim);border-color:var(--accent-border);}50%{background:rgba(99,102,241,0.32);border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,0.18);}}
.asset-card.flash{animation:card-flash .38s ease-in-out 4;}
.group-hdr{display:flex;align-items:center;justify-content:space-between;padding:6px 11px;border-radius:8px;background:var(--surface2);border:1px solid var(--border);cursor:pointer;user-select:none;transition:all .15s;margin-top:4px;}
.group-hdr:hover{border-color:var(--accent-border);}
.group-hdr.level-period{background:var(--surface);border-left:2px solid var(--accent);padding-left:9px;}
.group-hdr.level-month{background:var(--card-bg);border-left:2px solid rgba(99,102,241,0.3);padding-left:9px;margin-left:8px;}
.group-hdr.level-day{background:transparent;border:1px dashed var(--border);padding-left:9px;margin-left:18px;}
#tools-wrap{overflow:hidden;transition:max-height .35s cubic-bezier(.16,1,.3,1),opacity .2s;}
#tools-wrap.closed{max-height:0!important;opacity:0;pointer-events:none;}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);z-index:4000;display:flex;align-items:center;justify-content:center;padding:24px;}
.modal-box{background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:28px;max-width:440px;width:100%;box-shadow:0 25px 80px rgba(0,0,0,0.3);transition:var(--transition);}
#action-panel{position:absolute;bottom:24px;left:24px;width:340px;background:var(--surface);backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:22px;padding:22px;box-shadow:0 20px 60px rgba(0,0,0,0.3);z-index:2000;transition:var(--transition);}
.prog-track{height:4px;background:var(--border);border-radius:99px;overflow:hidden;}
.prog-fill{height:100%;border-radius:99px;transition:width .7s cubic-bezier(.16,1,.3,1);}
.theme-btn{width:52px;height:28px;border-radius:99px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;position:relative;transition:all .3s;flex-shrink:0;}
.theme-btn-knob{width:20px;height:20px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));position:absolute;top:3px;left:3px;transition:transform .3s cubic-bezier(.16,1,.3,1);display:flex;align-items:center;justify-content:center;}
[data-theme="light"] .theme-btn-knob{transform:translateX(24px);}
input[type=text],input[type=number],textarea,select{background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:10px;outline:none;font-family:inherit;transition:border-color .2s,var(--transition);}
input[type=text]:focus,input[type=number]:focus,textarea:focus,select:focus{border-color:var(--accent-border);}
input[type=text]::placeholder,textarea::placeholder{color:var(--text-muted);}
select option{background:var(--surface);color:var(--text);}
#toast{position:fixed;bottom:24px;right:24px;z-index:9000;background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:12px;padding:11px 18px;font-size:13px;font-weight:600;color:var(--text);box-shadow:0 8px 30px rgba(0,0,0,0.2);transform:translateY(80px);opacity:0;transition:all .3s cubic-bezier(.16,1,.3,1);}
