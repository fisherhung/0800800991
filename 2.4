<!-- Modals（儲存/分界/統計/紀錄/說明/人員） -->
<div id="modal-save" class="modal-bg" style="display:none;"><div class="modal-box"><h3 id="modal-title" style="font-size:19px;font-weight:900;color:var(--text);margin-bottom:4px;">儲存圖層</h3><p style="font-size:12px;color:var(--text-muted);margin-bottom:14px;">建議名稱格式：MMDD…（例：0306北段）</p><input id="modal-name" type="text" style="width:100%;padding:11px 14px;font-size:15px;font-weight:700;text-align:center;margin-bottom:12px;" placeholder="輸入名稱..."><div style="margin-bottom:12px;"><div style="font-size:10px;font-weight:700;color:var(--text-muted);letter-spacing:.1em;margin-bottom:7px;">期別</div><div style="display:flex;gap:7px;"><button class="period-select-btn" data-p="" onclick="selectModalPeriod('')" style="flex:1;padding:8px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);cursor:pointer;font-size:12px;font-weight:700;">自動</button><button class="period-select-btn" data-p="初" onclick="selectModalPeriod('初')" style="flex:1;padding:8px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);cursor:pointer;font-size:12px;font-weight:700;">初</button><button class="period-select-btn" data-p="中" onclick="selectModalPeriod('中')" style="flex:1;padding:8px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);cursor:pointer;font-size:12px;font-weight:700;">中</button><button class="period-select-btn" data-p="末" onclick="selectModalPeriod('末')" style="flex:1;padding:8px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);cursor:pointer;font-size:12px;font-weight:700;">末</button></div></div><div id="modal-status" style="display:none;padding:9px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.2);border-radius:10px;color:#f59e0b;font-size:12px;font-weight:600;margin-bottom:10px;">上傳中...</div><button id="modal-confirm" onclick="doUpload()" class="btn-accent" style="width:100%;padding:13px;font-size:14px;font-weight:800;border:none;">確認儲存</button><button onclick="closeModal()" style="width:100%;margin-top:8px;background:none;border:none;cursor:pointer;color:var(--text-muted);font-size:12px;font-weight:600;">取消</button></div></div>
