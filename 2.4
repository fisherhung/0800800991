function setFilter(f){curFilter=f;document.querySelectorAll('.chip[data-filter]').forEach(function(c){c.classList.toggle('active',c.dataset.filter===f);});collapsedGroups.forEach(function(v,k){if(k.indexOf('d:')===0)collapsedGroups.delete(k);});refreshAll();}
