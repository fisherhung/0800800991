function openPanel(id){activeId=id;var a=assets.get(id),s=a.statusData,st=s&&s.status||'none';document.getElementById('ui-name').innerText=a.name;var badge=document.getElementById('ui-badge');var claimBtn=document.getElementById('btn-claim'),doneBtn=document.getElementById('btn-done'),releaseBtn=document.getElementById('btn-release');var lockNotice=document.getElementById('lock-notice'),lockMsg=document.getElementById('lock-msg');if(st==='done')badge.innerHTML='<span style="display:inline-block;padding:4px 12px;border-radius:99px;font-size:12px;font-weight:700;background:rgba(16,185,129,.1);color:#10b981;border:1px solid rgba(16,185,129,.25);">✅ 已完工：'+(s&&s.operator_name)+'</span>';else if(st==='claimed')badge.innerHTML='<span style="display:inline-block;padding:4px 12px;border-radius:99px;font-size:12px;font-weight:700;background:rgba(245,158,11,.1);color:#f59e0b;border:1px solid rgba(245,158,11,.25);">👷 作業中：'+(s&&s.operator_name)+'</span>';else badge.innerHTML='<span style="display:inline-block;padding:4px 12px;border-radius:99px;font-size:12px;font-weight:700;background:var(--input-bg);color:var(--text-muted);border:1px solid var(--border);">開放認領</span>';var curUser=document.getElementById('user-select').value;var isOwner=s&&s.operator_name===curUser;if(st==='claimed'&&!isOwner){claimBtn.className='btn-accent btn-locked';claimBtn.onclick=null;doneBtn.className='btn-green btn-locked';doneBtn.onclick=null;releaseBtn.onclick=null;lockNotice.style.display='flex';lockMsg.innerText='此區塊由 '+(s&&s.operator_name)+' 認領中。';}else if(st==='done'){claimBtn.className='btn-accent btn-locked';claimBtn.onclick=null;doneBtn.className='btn-green btn-locked';doneBtn.onclick=null;releaseBtn.onclick=function(){updateStatus('none');};lockNotice.style.display='flex';lockMsg.innerText='此區塊已完工，如需修改請先釋出。';}else{claimBtn.className='btn-accent';claimBtn.onclick=function(){updateStatus('claimed');};doneBtn.className='btn-green';doneBtn.onclick=function(){updateStatus('done');};releaseBtn.onclick=function(){updateStatus('none');};lockNotice.style.display='none';}document.getElementById('action-panel').style.display='block';document.getElementById('panel-memo-input-wrap').classList.remove('open');if(document.getElementById('panel-memo-ta'))document.getElementById('panel-memo-ta').value='';renderPanelMemos(id);lucide.createIcons();refreshAll();if(a.type==='point')scrollToCard(id);else{if(curTab!=='img'){curTab='img';document.querySelectorAll('.tab').forEach(function(c){c.classList.toggle('active',c.dataset.type==='img');});renderList();}requestAnimationFrame(function(){var card=document.getElementById('card-'+id);if(card){card.scrollIntoView({behavior:'smooth',block:'center'});card.classList.remove('flash');void card.offsetWidth;card.classList.add('flash');setTimeout(function(){card.classList.remove('flash');},1800);}});}}
function closePanel(){document.getElementById('action-panel').style.display='none';activeId=null;refreshAll();}
function updateStatus(status){if(!activeId)return;var uName=document.getElementById('user-select').value;if(!uName&&status!=='none'){alert('請先選擇作業員');return;}var a=assets.get(activeId);var oldStatus=a&&a.statusData&&a.statusData.status||'none';var action=status==='claimed'?'claimed':status==='done'?'done':'released';sb.from('asset_status').upsert({asset_id:activeId,status:status,operator_name:status==='none'?null:uName,updated_at:new Date().toISOString()},{onConflict:'asset_id'}).then(function(){return writeAudit(activeId,a&&a.display_name||'',action,uName,oldStatus,status);}).then(function(){closePanel();});}
function triggerFile(id){document.getElementById(id).click();}
function doUpload(){var name=document.getElementById('modal-name').value.trim();if(!name)return;var btn=document.getElementById('modal-confirm'),st=document.getElementById('modal-status');btn.disabled=true;st.style.display='block';var uName=document.getElementById('user-select').value;var p;if(editId){var oldName=assets.get(editId)&&assets.get(editId).display_name||'';p=sb.from('assets').update({display_name:name,manual_period:pendingManualPeriod||null}).eq('id',editId).then(function(){return writeAudit(editId,name,'renamed',uName,oldName,name);}).then(function(){toast('已更新','success');});}else if(pendingPoints){var geojson={type:'FeatureCollection',features:pendingPoints};var fname=Date.now()+'.geojson';var blob=new Blob([JSON.stringify(geojson)],{type:'application/geo+json'});st.innerText='上傳至 Storage...';p=sb.storage.from('asset-points').upload(fname,blob,{contentType:'application/geo+json',upsert:false}).then(function(r){var pointsUrl=null;if(!r.error)pointsUrl=sb.storage.from('asset-points').getPublicUrl(fname).data.publicUrl;else toast('Storage 失敗','warn');st.innerText='寫入資料庫...';return sb.from('assets').insert({display_name:name,type:'point',points_url:pointsUrl||null,points_json:pointsUrl?null:pendingPoints,manual_period:pendingManualPeriod||null}).select().single();}).then(function(res){if(res.error)throw res.error;return writeAudit(res.data&&res.data.id,name,'created',uName,null,name);}).then(function(){toast('點位圖層已上傳 ✓','success');});}else if(pendingImg&&pendingJson){var fname2=Date.now()+'.jpg';var blob2=b64Blob(pendingImg);p=sb.storage.from('asset-images').upload(fname2,blob2,{contentType:'image/jpeg'}).then(function(r){var imgUrl=null,imgData=null;if(!r.error)imgUrl=sb.storage.from('asset-images').getPublicUrl(fname2).data.publicUrl;else imgData=pendingImg;return sb.from('assets').insert({display_name:name,type:'img',bounds_json:pendingJson,img_url:imgUrl,img_data:imgData,manual_period:pendingManualPeriod||null}).select().single();}).then(function(res){return writeAudit(res.data&&res.data.id,name,'created',uName,null,name);}).then(function(){toast('PNG 圖層已上傳','success');});}else p=Promise.resolve();p.then(function(){closeModal();}).catch(function(err){alert('上傳失敗：'+err.message);}).then(function(){btn.disabled=false;st.style.display='none';});}
function b64Blob(d){var parts=d.split(','),mime=parts[0].match(/:(.*?);/)[1];var bin=atob(parts[1]),u=new Uint8Array(bin.length);for(var i=0;i<bin.length;i++)u[i]=bin.charCodeAt(i);return new Blob([u],{type:mime});}
function editAssetName(id){editId=id;pendingManualPeriod=assets.get(id)&&assets.get(id).manual_period||'';selectModalPeriod(pendingManualPeriod);document.getElementById('modal-title').innerText='修改名稱';document.getElementById('modal-name').value=assets.get(id).name;document.getElementById('modal-save').style.display='flex';}
