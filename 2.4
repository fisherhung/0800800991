<!-- 顏色選擇 Popover -->
<div id="color-popover" class="color-popover">
  <div style="font-size:10px;font-weight:700;color:var(--text-muted);">選擇顏色</div>
  <div class="color-presets" id="color-presets"></div>
</div>

<script>
(function(){if(typeof toGeoJSON==='undefined'&&typeof togeojson!=='undefined')window.toGeoJSON=togeojson;})();

var SUPA_URL='https://uxcewvrsipqoeinbdhtw.supabase.co';
var SUPA_KEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV4Y2V3dnJzaXBxb2VpbmJkaHR3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI1NTM3OTQsImV4cCI6MjA4ODEyOTc5NH0.leM7osk_YK-ypDpF1cM-G5Kriq3pAUI6-8PS_jcwJXg';
var EDGE_BASE=SUPA_URL+'/functions/v1';
proj4.defs('EPSG:3826','+proj=tmerc +lat_0=0 +lon_0=121 +k=0.9999 +x_0=250000 +y_0=0 +ellps=GRS80 +units=m +no_defs');

var sb,map,tileLayer;
var assets=new Map(),operators=[];
var activeId=null,curFilter='all',curTab='point',curOp='all';
var pendingJson=null,pendingImg=null,pendingPoints=null,editId=null;
var isDark=true,sortOrder='asc';
var locateMarker=null,_ctxCoord=null;
var collapsedGroups=new Map();
var activePeriod='all',pendingManualPeriod='';
var memoOpen=false,memos=[],editingMemoId=null;
var memoComments={},expandedComments=new Set();
var periodCfg={earlyEnd:'0305',midEnd:'0320'};
var statsPeriod='all',_openPopoverId=null;
var canvasRenderer=L.canvas({padding:0.5});

// ══ KML 狀態 ══
// kmlLayers: [{id,name,color,visible,geojson_url,storage_path,_geoJSON}]
var kmlLayers=[];
// kmlPolylines: {id: [L.Polyline, ...]} — 地圖上實際的線段，是唯一真相來源
var kmlPolylines={};
var roadPanelOpen=false;
var kmlDiffLayer=null;
var KML_COLORS=['#94a3b8','#818cf8','#f59e0b','#10b981','#ef4444','#ec4899','#06b6d4','#f97316','#ffffff'];

// ══ KML 核心操作 ══

// 把某個 entry 的線段畫到地圖，存入 kmlPolylines[id]
function kmlShow(id){
  var en=_getKml(id);
  if(!en||!en._geoJSON)return;
  kmlHide(id); // 先清掉舊的避免重複
  var lines=[];
  (en._geoJSON.features||[]).forEach(function(f){
    var geom=f.geometry;if(!geom)return;
    var rings=geom.type==='LineString'?[geom.coordinates]:geom.coordinates||[];
    rings.forEach(function(coords){
      var lls=coords.map(function(c){return[c[1],c[0]];});
      if(lls.length>1)lines.push(L.polyline(lls,{color:en.color,weight:2.5,opacity:0.9}).addTo(map));
    });
  });
  kmlPolylines[id]=lines;
  en.visible=true;
}

// 把某個 entry 的線段從地圖移除
function kmlHide(id){
  var en=_getKml(id);if(en)en.visible=false;
  var lines=kmlPolylines[id]||[];
  lines.forEach(function(pl){try{map.removeLayer(pl);}catch(e){}});
  kmlPolylines[id]=[];
}

function _getKml(id){return kmlLayers.filter(function(x){return x.id===id;})[0]||null;}

// ══ 載入 KML 圖層清單 ══
function loadKmlLayers(){
  // 先清除所有地圖上的 KML 線段
  Object.keys(kmlPolylines).forEach(function(id){kmlHide(id);});
  kmlPolylines={};
  kmlLayers=[];
  return sb.from('kml_layers').select('*').order('created_at',{ascending:true}).then(function(r){
    var rows=r.data||[];
    if(!rows.length){renderKmlList();return;}
    var done=0;
    rows.forEach(function(row){
      var en={id:row.id,name:row.name,color:row.color,visible:false,
        geojson_url:row.geojson_url,storage_path:row.storage_path,_geoJSON:null};
      kmlLayers.push(en);
      fetch(row.geojson_url).then(function(res){return res.json();}).then(function(gj){
        en._geoJSON=gj;
        // ★ 預設不顯示，什麼都不做
      }).catch(function(){}).then(function(){
        done++;if(done===rows.length)renderKmlList();
      });
    });
  });
}

// ══ 渲染 KML 列表 ══
function renderKmlList(){
  var el=document.getElementById('kml-layer-list');
  if(!el)return;
  el.innerHTML='';
  if(!kmlLayers.length){
    el.innerHTML='<div style="font-size:11px;color:var(--text-muted);text-align:center;padding:4px 0;">尚無 KML 圖層</div>';
    return;
  }
  kmlLayers.forEach(function(entry){
    var card=document.createElement('div');card.className='kml-layer-card';
    // 顏色點
    var dot=document.createElement('div');dot.className='kml-color-dot';
    dot.style.background=entry.color;dot.title='點擊換色';
    (function(eid,d){d.onclick=function(e){e.stopPropagation();openColorPopover(eid,d);};})(entry.id,dot);
    // 名稱
    var nameEl=document.createElement('span');nameEl.className='kml-layer-name';
    nameEl.textContent=entry.name;nameEl.title='雙擊改名';
    (function(eid,nel){
      nel.ondblclick=function(){
        var inp=document.createElement('input');inp.type='text';
        inp.style.cssText='flex:1;font-size:12px;font-weight:600;padding:2px 6px;border-radius:6px;min-width:0;';
        inp.value=nel.textContent;nel.replaceWith(inp);inp.focus();inp.select();
        function commit(){
          var n=inp.value.trim()||entry.name;
          sb.from('kml_layers').update({name:n}).eq('id',eid).then(function(){
            var en=_getKml(eid);if(en)en.name=n;renderKmlList();toast('已改名','success');
          });
        }
        inp.onblur=commit;inp.onkeydown=function(ev){if(ev.key==='Enter')inp.blur();if(ev.key==='Escape'){inp.value=entry.name;inp.blur();}};
      };
    })(entry.id,nameEl);
    // ★ 眼睛按鈕：每次根據 kmlPolylines[id].length 判斷目前是否顯示
    var isOn=(kmlPolylines[entry.id]&&kmlPolylines[entry.id].length>0);
    var eyeBtn=document.createElement('button');
    eyeBtn.className='kml-eye-btn'+(isOn?' on':'');
    eyeBtn.textContent=isOn?'👁':'🙈';
    eyeBtn.title=isOn?'點擊隱藏':'點擊顯示';
    (function(eid,btn){
      btn.onclick=function(ev){
        ev.stopPropagation();
        var currently=(kmlPolylines[eid]&&kmlPolylines[eid].length>0);
        if(currently){
          kmlHide(eid);
          btn.textContent='🙈';btn.title='點擊顯示';btn.classList.remove('on');
        }else{
          var en=_getKml(eid);
          if(!en._geoJSON){
            // 還沒載完，重新 fetch
            if(!en.geojson_url)return;
            btn.textContent='⏳';btn.disabled=true;
            fetch(en.geojson_url).then(function(r){return r.json();}).then(function(gj){
              en._geoJSON=gj;kmlShow(eid);
              btn.textContent='👁';btn.title='點擊隱藏';btn.classList.add('on');btn.disabled=false;
            }).catch(function(){btn.textContent='🙈';btn.disabled=false;});
            return;
          }
          kmlShow(eid);
          btn.textContent='👁';btn.title='點擊隱藏';btn.classList.add('on');
        }
        sb.from('kml_layers').update({visible:!currently}).eq('id',eid).catch(function(){});
      };
    })(entry.id,eyeBtn);
    // 刪除
    var delBtn=document.createElement('button');delBtn.className='kml-del-btn';delBtn.textContent='🗑️';delBtn.title='刪除';
    (function(eid){
      delBtn.onclick=function(ev){
        ev.stopPropagation();
        if(!confirm('確定刪除此 KML 圖層？'))return;
        kmlHide(eid);delete kmlPolylines[eid];
        var en=_getKml(eid);
        if(en&&en.storage_path)sb.storage.from('kml-files').remove([en.storage_path]).catch(function(){});
        sb.from('kml_layers').delete().eq('id',eid).then(function(){
          kmlLayers=kmlLayers.filter(function(x){return x.id!==eid;});
          renderKmlList();toast('已刪除','info');
        });
      };
    })(entry.id);
    card.append(dot,nameEl,eyeBtn,delBtn);el.appendChild(card);
  });
}

// ══ 顏色選擇 ══
var _colorTargetId=null;
function openColorPopover(entryId,anchorEl){
  _colorTargetId=entryId;
  var pop=document.getElementById('color-popover');
  var presets=document.getElementById('color-presets');presets.innerHTML='';
  var en=_getKml(entryId);var cur=en?en.color:'';
  KML_COLORS.forEach(function(c){
    var s=document.createElement('div');s.className='color-preset'+(c===cur?' sel':'');
    s.style.background=c;s.title=c;
    s.onclick=function(){applyKmlColor(entryId,c);pop.style.display='none';};
    presets.appendChild(s);
  });
  var rect=anchorEl.getBoundingClientRect();
  pop.style.left=Math.min(rect.left,window.innerWidth-180)+'px';
  pop.style.top=(rect.bottom+4)+'px';
  pop.style.display='flex';
  setTimeout(function(){
    document.addEventListener('click',function cp(ev){
      if(!pop.contains(ev.target)){pop.style.display='none';document.removeEventListener('click',cp);}
    });
  },0);
}
function applyKmlColor(entryId,color){
  var en=_getKml(entryId);if(!en)return;
  en.color=color;
  // 重新畫（如果顯示中）
  if(kmlPolylines[entryId]&&kmlPolylines[entryId].length>0){kmlHide(entryId);kmlShow(entryId);}
  sb.from('kml_layers').update({color:color}).eq('id',entryId).catch(function(){});
  renderKmlList();
}

// ══ KML 上傳 ══
function uploadKmlFile(file){
  var reader=new FileReader();
  reader.onload=function(ev){
    var parser=new DOMParser();
    var kmlDoc=parser.parseFromString(ev.target.result,'application/xml');
    var tgj=window.toGeoJSON||window.togeojson;
    if(!tgj){toast('toGeoJSON 函式庫未載入','error');return;}
    var gj=tgj.kml(kmlDoc);
    var lines={type:'FeatureCollection',features:(gj.features||[]).filter(function(ft){
      var t=ft.geometry&&ft.geometry.type;return t==='LineString'||t==='MultiLineString';
    })};
    if(!lines.features.length){toast('KML 中找不到線段','warn');return;}
    toast('上傳中…','info');
    var fname='kml/'+Date.now()+'_'+file.name.replace(/[^a-zA-Z0-9._-]/g,'_');
