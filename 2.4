function renderOpUI(){var sel=document.getElementById('user-select'),cur=sel.value;sel.innerHTML='<option value="">選擇作業員...</option>';operators.forEach(function(op){var o=document.createElement('option');o.value=op.name;o.innerText=op.name;sel.appendChild(o);});sel.value=cur;var list=document.getElementById('op-list');list.innerHTML='';operators.forEach(function(op){var item=document.createElement('div');item.style.cssText='display:flex;align-items:center;justify-content:space-between;padding:9px 11px;background:var(--card-bg);border:1px solid var(--border);border-radius:10px;';item.innerHTML='<div style="display:flex;align-items:center;gap:9px;"><div style="width:7px;height:7px;border-radius:50%;background:var(--accent);"></div><span style="font-weight:700;font-size:14px;color:var(--text);">'+op.name+'</span></div><div style="display:flex;gap:3px;"><button class="ren-btn" style="width:27px;height:27px;border-radius:6px;border:none;background:none;cursor:pointer;font-size:14px;">✏️</button><button class="dop-btn" style="width:27px;height:27px;border-radius:6px;border:none;background:none;cursor:pointer;font-size:14px;">🗑️</button></div>';(function(oid,oname){item.querySelector('.ren-btn').addEventListener('click',function(){renameOperator(oid,oname);});item.querySelector('.dop-btn').addEventListener('click',function(){deleteOperator(oid);});})(op.id,op.name);list.appendChild(item);});}
function addOperator(){var name=document.getElementById('new-op-name').value.trim();if(name){sb.from('operators').insert({name:name}).then(function(){document.getElementById('new-op-name').value='';toast(name+' 已新增','success');});}}
