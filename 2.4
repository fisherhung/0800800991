ubStyle+'">'+sub+'</div>';(function(aid){focusDiv.addEventListener('click',function(){focusOn(aid);});})(id);var btnWrap=document.createElement('div');btnWrap.style.cssText='display:flex;gap:2px;flex-shrink:0;';if(asset.type==='point'){var csvBtn=document.createElement('button');csvBtn.style.cssText='width:24px;height:24px;border-radius:6px;border:1px solid rgba(16,185,129,.35);background:rgba(16,185,129,.18);cursor:pointer;color:#10b981;display:flex;align-items:center;justify-content:center;font-size:11px;';csvBtn.title='匯出 CSV';csvBtn.textContent='↓';(function(aid){csvBtn.addEventListener('click',function(){downloadCSV(aid);});})(id);btnWrap.appendChild(csvBtn);}var editBtn=document.createElement('button');editBtn.style.cssText='width:24px;height:24px;border-radius:6px;border:none;background:none;cursor:pointer;color:var(--text-muted);display:flex;align-items:center;justify-content:center;font-size:13px;opacity:0.6;';editBtn.title='改名';editBtn.textContent='✏️';(function(aid){editBtn.addEventListener('click',function(){editAssetName(aid);});})(id);var delBtn=document.createElement('button');delBtn.style.cssText='width:24px;height:24px;border-radius:6px;border:none;background:none;cursor:pointer;color:var(--text-muted);display:flex;align-items:center;justify-content:center;font-size:13px;opacity:0.6;';delBtn.title='刪除';delBtn.textContent='🗑️';(function(aid){delBtn.addEventListener('click',function(){deleteAsset(aid);});})(id);btnWrap.append(editBtn,delBtn);var dot=document.createElement('div');dot.style.cssText='width:7px;height:7px;border-radius:50%;background:'+dotC+';flex-shrink:0;box-shadow:0 0 5px '+dotC+'66;';card.append(dot,focusDiv,periodBtn,btnWrap);return card;}
function refreshAll(){applyMapStyles();renderList();}
