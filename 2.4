// ══ 消除預覽 ══
function setRoadStatus(msg,show){if(show===undefined)show=true;var el=document.getElementById('road-status');el.textContent=msg;el.classList.toggle('show',show);}
function calcTotalLength(gj){var l=0;(gj&&gj.features||[]).forEach(function(f){var geom=f.geometry;if(!geom)return;var coords=geom.type==='LineString'?[geom.coordinates]:geom.coordinates||[];coords.forEach(function(ring){for(var i=1;i<ring.length;i++)l+=Math.hypot(ring[i][0]-ring[i-1][0],ring[i][1]-ring[i-1][1]);});});return l;}
function previewDiff(){
  var allFeatures=[];
  kmlLayers.forEach(function(en){if(kmlPolylines[en.id]&&kmlPolylines[en.id].length>0&&en._geoJSON)allFeatures=allFeatures.concat(en._geoJSON.features||[]);});
  if(!allFeatures.length){toast('請先點👁開啟至少一個 KML 圖層','warn');return;}
  var mergedGJ={type:'FeatureCollection',features:allFeatures};
  var btn=document.getElementById('btn-preview');btn.innerHTML='<span class="kml-spinner"></span>計算中…';btn.disabled=true;
  setRoadStatus('⏳ 計算中…');
  fetch(EDGE_BASE+'/diff_lines_by_markers',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+SUPA_KEY},body:JSON.stringify({lines:mergedGJ})})
    .then(function(res){if(!res.ok)throw new Error('HTTP '+res.status);return res.json();})
    .then(function(result){var diffGJ=result.geojson||result;if(!diffGJ||!diffGJ.features)throw new Error('格式錯誤');showDiffResult(mergedGJ,diffGJ);toast('後端預覽完成','success');})
    .catch(function(err){console.warn('fallback:',err.message);frontendDiffFallback(mergedGJ);})
    .then(function(){btn.innerHTML='⚡ 預覽消除';btn.disabled=false;});
}
function showDiffResult(origGJ,diffGJ){
  if(kmlDiffLayer)map.removeLayer(kmlDiffLayer);
  kmlDiffLayer=L.geoJSON(diffGJ,{style:{color:'#818cf8',weight:3,opacity:0.95}}).addTo(map);
  var cnt=diffGJ.features.length;var orig=calcTotalLength(origGJ);var pct=orig>0?Math.round((1-calcTotalLength(diffGJ)/orig)*100):0;
  document.getElementById('diff-stat').textContent='剩餘 '+cnt+' 段（消除 '+pct+'%）';
  setRoadStatus('✅ 預覽完成（不儲存）');
  document.getElementById('btn-clear-diff').style.display='block';
}
function frontendDiffFallback(origGJ){
  toast('Edge Function 未連線，前端模擬','warn');
  var pts=[];
  assets.forEach(function(a){if(a.type==='point'&&a._rawFeatures){a._rawFeatures.forEach(function(f){var lat=null,lng=null;if(f.geometry&&f.geometry.coordinates){var cx=parseFloat(f.geometry.coordinates[0]),cy=parseFloat(f.geometry.coordinates[1]);if(looksWGS84(cx,cy)){lng=cx;lat=cy;}else{var w=to84(cx,cy);lng=w[0];lat=w[1];}}if(lat!==null)pts.push([lng,lat]);});}});
  var THRESH=0.0001617;var resultFeatures=[];
  (origGJ.features||[]).forEach(function(f){var geom=f.geometry;if(!geom)return;var coords=geom.type==='LineString'?[geom.coordinates]:geom.coordinates;coords.forEach(function(ring){var seg=[];ring.forEach(function(pt){var near=pts.some(function(p){return Math.hypot(pt[0]-p[0],pt[1]-p[1])<THRESH;});if(!near){seg.push(pt);}else{if(seg.length>=2)resultFeatures.push({type:'Feature',geometry:{type:'LineString',coordinates:seg.slice()},properties:{}});seg=[];}});if(seg.length>=2)resultFeatures.push({type:'Feature',geometry:{type:'LineString',coordinates:seg},properties:{}});});});
  var diffGJ={type:'FeatureCollection',features:resultFeatures};
  showDiffResult(origGJ,diffGJ);
  document.getElementById('diff-stat').textContent='剩餘 '+resultFeatures.length+' 段（前端模擬）';
  setRoadStatus('⚠️ 前端模擬');
  var btn=document.getElementById('btn-preview');btn.innerHTML='⚡ 預覽消除';btn.disabled=false;
}
function clearDiff(){
  if(kmlDiffLayer){map.removeLayer(kmlDiffLayer);kmlDiffLayer=null;}
  document.getElementById('diff-stat').textContent='開啟圖層後可預覽';
  document.getElementById('btn-clear-diff').style.display='none';
  setRoadStatus('',false);toast('已清除消除預覽','info');
}

