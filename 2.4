<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>花蓮人行道圖資協作系統</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/proj4js/2.8.0/proj4.js"></script>
<script src="https://unpkg.com/lucide@latest"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/togeojson/0.16.0/togeojson.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
:root{
  --bg:#0a0f1e;--surface:#111827;--surface2:#1f2937;--border:rgba(255,255,255,0.07);
  --text:#f1f5f9;--text-muted:#64748b;--text-sub:#94a3b8;
  --card-bg:rgba(255,255,255,0.02);--card-hover:rgba(255,255,255,0.05);
  --input-bg:rgba(255,255,255,0.04);--header-bg:rgba(10,15,30,0.97);
  --sidebar-bg:rgba(17,24,39,0.98);--accent:#6366f1;--accent2:#8b5cf6;
  --accent-dim:rgba(99,102,241,0.12);--accent-border:rgba(99,102,241,0.25);
  --green:#10b981;--amber:#f59e0b;--sidebar-w:400px;--header-h:76px;
  --transition:background 0.3s,color 0.3s,border-color 0.3s;
}
[data-theme="light"]{
  --bg:#f1f5f9;--surface:#ffffff;--surface2:#f8fafc;--border:rgba(0,0,0,0.08);
  --text:#0f172a;--text-muted:#94a3b8;--text-sub:#64748b;
  --card-bg:rgba(255,255,255,0.8);--card-hover:rgba(99,102,241,0.04);
  --input-bg:rgba(0,0,0,0.03);--header-bg:rgba(255,255,255,0.97);
  --sidebar-bg:rgba(255,255,255,0.98);
  --accent-dim:rgba(99,102,241,0.08);--accent-border:rgba(99,102,241,0.2);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Inter','Noto Sans TC',sans-serif;background:var(--bg);color:var(--text);overflow:hidden;height:100vh;display:flex;flex-direction:column;transition:var(--transition);}
::-webkit-scrollbar{width:3px;}::-webkit-scrollbar-thumb{background:rgba(128,128,128,0.2);border-radius:99px;}
#loading{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.spinner{width:44px;height:44px;border:3px solid rgba(99,102,241,0.15);border-top-color:#6366f1;border-radius:50%;animation:spin .8s linear infinite;margin-bottom:18px;}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes live-pulse{0%{box-shadow:0 0 0 0 rgba(16,185,129,0.7);}60%{box-shadow:0 0 0 6px rgba(16,185,129,0);}100%{box-shadow:0 0 0 0 rgba(16,185,129,0);}}
@keyframes memo-badge-pop{0%{transform:scale(0.5);opacity:0}100%{transform:scale(1);opacity:1}}
@keyframes memo-row-in{0%{opacity:0;transform:translateY(4px)}100%{opacity:1;transform:translateY(0)}}
@keyframes card-flash{0%,100%{background:var(--accent-dim);border-color:var(--accent-border);}50%{background:rgba(99,102,241,0.32);border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,0.18);}}
#db-dot.live{animation:live-pulse 1.6s ease-out infinite;}
header{height:var(--header-h);background:var(--header-bg);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 24px;z-index:2000;flex-shrink:0;transition:var(--transition);}
.sidebar{width:var(--sidebar-w);flex-shrink:0;background:var(--sidebar-bg);backdrop-filter:blur(20px);border-right:1px solid var(--border);display:flex;flex-direction:column;height:100%;transition:margin .4s cubic-bezier(.16,1,.3,1),var(--transition);}
.sidebar.collapsed{margin-left:calc(-1 * var(--sidebar-w));}
.tt{background:var(--surface)!important;color:var(--text)!important;border:1px solid var(--border)!important;border-radius:8px;padding:5px 12px;font-weight:700;font-size:12px;box-shadow:0 4px 20px rgba(0,0,0,0.2);}
.chip{cursor:pointer;white-space:nowrap;font-weight:600;font-size:12px;padding:4px 12px;border-radius:99px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);transition:all .2s;}
.chip:hover{border-color:var(--accent-border);color:var(--accent);}
.chip.active{background:var(--accent-dim);border-color:var(--accent-border);color:var(--accent);}
.op-chip{cursor:pointer;white-space:nowrap;font-weight:600;font-size:12px;padding:3px 10px;border-radius:99px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);transition:all .2s;}
.op-chip:hover{border-color:var(--accent-border);color:var(--accent);}
.op-chip.active{background:var(--accent-dim);border-color:var(--accent-border);color:var(--accent);}
.period-chip{cursor:pointer;white-space:nowrap;font-weight:700;font-size:12px;padding:4px 13px;border-radius:99px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);transition:all .2s;}
.period-chip:hover{border-color:var(--accent-border);color:var(--accent);}
.period-chip.active{background:var(--accent-dim);border-color:var(--accent-border);color:var(--accent);}
.tab{cursor:pointer;padding:10px 0;font-weight:700;font-size:13px;border-bottom:2px solid transparent;transition:all .2s;color:var(--text-muted);text-align:center;flex:1;}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.btn-accent{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border:none;cursor:pointer;font-weight:700;transition:all .2s;border-radius:12px;}
.btn-accent:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 8px 25px rgba(99,102,241,0.3);}
.btn-green{background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.25);color:#10b981;border-radius:12px;cursor:pointer;font-weight:700;transition:all .2s;}
.btn-green:hover{background:rgba(16,185,129,0.2);}
.btn-ghost{background:var(--input-bg);border:1px solid var(--border);color:var(--text-muted);border-radius:10px;cursor:pointer;font-weight:600;transition:all .2s;}
.btn-ghost:hover{background:var(--card-hover);color:var(--text);}
.btn-locked{background:var(--input-bg)!important;border:1px solid var(--border)!important;color:var(--text-muted)!important;opacity:.4!important;cursor:not-allowed!important;transform:none!important;box-shadow:none!important;}
.asset-card{display:flex;align-items:center;gap:10px;padding:9px 11px;border-radius:10px;border:1px solid var(--border);background:var(--card-bg);transition:all .15s;}
.asset-card:hover{background:var(--card-hover);border-color:var(--accent-border);}
.asset-card.active{background:var(--accent-dim);border-color:var(--accent-border);}
.asset-card.flash{animation:card-flash .38s ease-in-out 4;}
.group-hdr{display:flex;align-items:center;justify-content:space-between;padding:6px 11px;border-radius:8px;background:var(--surface2);border:1px solid var(--border);cursor:pointer;user-select:none;transition:all .15s;margin-top:4px;}
.group-hdr:hover{border-color:var(--accent-border);}
.group-hdr.level-period{background:var(--surface);border-left:2px solid var(--accent);padding-left:9px;}
.group-hdr.level-month{background:var(--card-bg);border-left:2px solid rgba(99,102,241,0.3);padding-left:9px;margin-left:8px;}
.group-hdr.level-day{background:transparent;border:1px dashed var(--border);padding-left:9px;margin-left:18px;}
#tools-wrap{overflow:hidden;transition:max-height .35s cubic-bezier(.16,1,.3,1),opacity .2s;}
#tools-wrap.closed{max-height:0!important;opacity:0;pointer-events:none;}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,0.6);backdrop-filter:blur(8px);z-index:4000;display:flex;align-items:center;justify-content:center;padding:24px;}
.modal-box{background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:28px;max-width:440px;width:100%;box-shadow:0 25px 80px rgba(0,0,0,0.3);transition:var(--transition);}
#action-panel{position:absolute;bottom:24px;left:24px;width:340px;background:var(--surface);backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:22px;padding:22px;box-shadow:0 20px 60px rgba(0,0,0,0.3);z-index:2000;transition:var(--transition);}
.prog-track{height:4px;background:var(--border);border-radius:99px;overflow:hidden;}
.prog-fill{height:100%;border-radius:99px;transition:width .7s cubic-bezier(.16,1,.3,1);}
.theme-btn{width:52px;height:28px;border-radius:99px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;position:relative;transition:all .3s;flex-shrink:0;}
.theme-btn-knob{width:20px;height:20px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));position:absolute;top:3px;left:3px;transition:transform .3s cubic-bezier(.16,1,.3,1);display:flex;align-items:center;justify-content:center;}
[data-theme="light"] .theme-btn-knob{transform:translateX(24px);}
input[type=text],input[type=number],textarea,select{background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:10px;outline:none;font-family:inherit;transition:border-color .2s,var(--transition);}
input[type=text]:focus,input[type=number]:focus,textarea:focus,select:focus{border-color:var(--accent-border);}
input[type=text]::placeholder,textarea::placeholder{color:var(--text-muted);}
select option{background:var(--surface);color:var(--text);}
#toast{position:fixed;bottom:24px;right:24px;z-index:9000;background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:12px;padding:11px 18px;font-size:13px;font-weight:600;color:var(--text);box-shadow:0 8px 30px rgba(0,0,0,0.2);transform:translateY(80px);opacity:0;transition:all .3s cubic-bezier(.16,1,.3,1);}
#toast.show{transform:translateY(0);opacity:1;}
#map{height:100%;width:100%;}
#locate-input{background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:9px;outline:none;font-family:inherit;font-size:13px;font-weight:600;padding:6px 12px;width:210px;transition:border-color .2s,var(--transition);}
#locate-input:focus{border-color:var(--accent-border);}
#locate-input::placeholder{color:var(--text-muted);font-weight:500;}
#locate-btn{height:32px;padding:0 14px;font-size:12px;font-weight:700;border:none;border-radius:9px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;cursor:pointer;white-space:nowrap;}
.hl{background:rgba(99,102,241,0.35);border-radius:3px;color:var(--text);}
.donut-wrap{position:relative;display:flex;align-items:center;justify-content:center;}
.donut-center{position:absolute;text-align:center;pointer-events:none;}
#memo-panel{position:fixed;top:0;right:0;bottom:0;width:380px;background:var(--sidebar-bg);border-left:1px solid var(--border);z-index:3500;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .4s cubic-bezier(.16,1,.3,1);}
#memo-panel.open{transform:translateX(0);}
.memo-card{padding:12px 14px;background:var(--card-bg);border:1px solid var(--border);border-radius:12px;transition:all .15s;}
.memo-card:hover{background:var(--card-hover);}
.memo-card.pinned{border-left:3px solid var(--amber);}
.period-inline-btn{display:inline-flex;align-items:center;gap:3px;padding:1px 7px;border-radius:99px;font-size:10px;font-weight:800;cursor:pointer;border:1px solid rgba(99,102,241,0.4);background:rgba(99,102,241,0.12);color:#a5b4fc;transition:all .15s;user-select:none;position:relative;}
.period-inline-btn:hover{background:rgba(99,102,241,0.25);border-color:var(--accent);}
.period-inline-btn.auto{background:rgba(100,116,139,0.12);border-color:rgba(100,116,139,0.3);color:var(--text-muted);}
.period-inline-btn.auto:hover{background:rgba(99,102,241,0.12);border-color:rgba(99,102,241,0.4);color:#a5b4fc;}
.period-popover{position:absolute;bottom:calc(100% + 6px);left:0;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:5px;display:flex;gap:4px;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,0.3);}
.period-popover button{padding:4px 10px;border-radius:7px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);cursor:pointer;font-size:11px;font-weight:700;transition:all .15s;}
.period-popover button:hover,.period-popover button.active{background:var(--accent-dim);border-color:var(--accent-border);color:var(--accent);}
.mmdd-input{width:54px;padding:3px 7px;font-size:12px;font-weight:700;text-align:center;border-radius:7px;}
#batch-progress-wrap{display:none;margin:0 12px 8px;padding:10px 14px;background:var(--surface2);border:1px solid var(--border);border-radius:12px;}
#batch-progress-wrap.show{display:block;}
.batch-prog-track{height:6px;background:var(--border);border-radius:99px;overflow:hidden;margin-top:6px;}
.batch-prog-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,#6366f1,#10b981);transition:width .3s;}
#panel-memo-section{margin-top:14px;border-top:1px solid var(--border);padding-top:12px;}
#panel-memo-section .pm-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
#panel-memo-section .pm-title{display:flex;align-items:center;gap:6px;font-size:11px;font-weight:800;color:var(--text-muted);letter-spacing:.1em;}
#panel-memo-section .pm-add-btn{display:flex;align-items:center;gap:4px;padding:3px 9px;border-radius:7px;border:1px solid var(--accent-border);background:var(--accent-dim);color:var(--accent);cursor:pointer;font-size:11px;font-weight:700;transition:all .15s;}
#panel-memo-section .pm-add-btn:hover{background:rgba(99,102,241,0.2);}
.pm-memo-row{display:flex;align-items:flex-start;gap:7px;padding:7px 9px;border-radius:9px;background:var(--card-bg);border:1px solid var(--border);cursor:pointer;transition:all .15s;animation:memo-row-in .2s ease;}
.pm-memo-row:hover{background:var(--card-hover);border-color:var(--accent-border);}
.pm-memo-row.resolved{opacity:0.5;}
.pm-memo-row .pm-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.pm-memo-row .pm-content{flex:1;min-width:0;}
.pm-memo-row .pm-text{font-size:12px;font-weight:600;color:var(--text);line-height:1.45;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.pm-memo-row .pm-meta{display:flex;align-items:center;gap:5px;margin-top:2px;}
.pm-memo-row .pm-op{font-size:10px;font-weight:700;color:var(--accent);}
.pm-memo-row .pm-time{font-size:10px;color:var(--text-muted);}
.pm-memo-row .pm-comments{font-size:10px;font-weight:700;color:var(--text-muted);background:var(--surface2);border-radius:99px;padding:1px 6px;flex-shrink:0;}
#panel-memo-input-wrap{display:none;margin-top:8px;gap:6px;flex-direction:column;}
#panel-memo-input-wrap.open{display:flex;}
#panel-memo-input-wrap textarea{padding:8px 10px;font-size:12px;resize:none;border-radius:9px;width:100%;}
#panel-memo-input-wrap .pm-submit-row{display:flex;gap:6px;}
/* KML面板 */
#road-panel{position:absolute;bottom:24px;right:24px;width:310px;background:var(--surface);backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,0.35);z-index:2100;overflow:hidden;transition:var(--transition);}
#road-panel-header{display:flex;align-items:center;justify-content:space-between;padding:14px 16px 10px;border-bottom:1px solid var(--border);cursor:pointer;user-select:none;}
.road-upload-btn{width:100%;padding:9px;border-radius:10px;border:1px dashed var(--accent-border);background:var(--accent-dim);color:var(--accent);font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .2s;}
.road-upload-btn:hover{background:rgba(99,102,241,0.2);}
.kml-layer-card{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:10px;background:var(--card-bg);border:1px solid var(--border);}
.kml-color-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;cursor:pointer;border:2px solid rgba(255,255,255,0.2);}
.kml-layer-name{flex:1;font-size:12px;font-weight:600;color:var(--text);min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:default;}
.kml-eye-btn{width:28px;height:28px;border-radius:7px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;transition:all .15s;}
.kml-eye-btn.on{border-color:var(--accent-border);background:var(--accent-dim);}
.kml-del-btn{width:24px;height:24px;border-radius:6px;border:none;background:none;cursor:pointer;font-size:13px;opacity:0.55;flex-shrink:0;}
.kml-del-btn:hover{opacity:1;}
.road-diff-row{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:10px;background:rgba(99,102,241,0.06);border:1px solid var(--accent-border);}
#road-status{padding:7px 10px;border-radius:9px;font-size:11px;font-weight:600;background:rgba(99,102,241,0.08);border:1px solid var(--accent-border);color:var(--text-sub);display:none;}
#road-status.show{display:block;}
.kml-spinner{display:inline-block;width:12px;height:12px;border:2px solid rgba(255,255,255,0.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;margin-right:5px;vertical-align:middle;}
.color-popover{position:absolute;z-index:9999;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px;box-shadow:0 8px 24px rgba(0,0,0,0.3);display:none;flex-direction:column;gap:8px;}
.color-presets{display:flex;gap:6px;flex-wrap:wrap;}
.color-preset{width:20px;height:20px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .15s;}
.color-preset:hover{transform:scale(1.25);}
.color-preset.sel{border-color:#fff;}
</style>
</head>
<body>
<div id="loading"><div class="spinner"></div><p style="font-size:13px;font-weight:700;color:#6366f1;letter-spacing:.15em;">CONNECTING TO DATABASE</p><p style="font-size:11px;color:var(--text-muted);margin-top:5px;">花蓮人行道圖資協作系統</p></div>
<div id="toast"></div>
<header>
  <div style="display:flex;align-items:center;gap:14px;">
    <button id="btn-toggle" style="width:38px;height:38px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-muted);flex-shrink:0;"><i data-lucide="panel-left" style="width:16px;height:16px;"></i></button>
    <div>
      <div style="font-size:26px;font-weight:900;color:var(--text);letter-spacing:-.04em;line-height:1.1;">花蓮人行道圖資協作系統</div>
      <div style="font-size:10px;font-weight:600;color:var(--text-muted);letter-spacing:.12em;margin-top:3px;">INFRASTRUCTURE · GIS COLLABORATION PLATFORM</div>
    </div>
  </div>
  <div style="display:flex;align-items:center;gap:10px;">
    <div style="display:flex;align-items:center;gap:6px;padding:5px 10px;background:var(--input-bg);border:1px solid var(--border);border-radius:12px;">
      <i data-lucide="crosshair" style="width:13px;height:13px;color:var(--accent);flex-shrink:0;"></i>
      <input id="locate-input" type="text" placeholder="97座標：305000, 2652000">
      <button id="locate-btn" onclick="locateCoord()">定位</button>
    </div>
    <button class="theme-btn" onclick="toggleTheme()"><div class="theme-btn-knob"><i id="theme-icon" data-lucide="moon" style="width:11px;height:11px;color:#fff;"></i></div></button>
    <button onclick="openHelp()" style="width:34px;height:34px;border-radius:99px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-muted);"><i data-lucide="help-circle" style="width:16px;height:16px;"></i></button>
    <button onclick="toggleMemo()" id="memo-btn" style="display:flex;align-items:center;gap:6px;padding:7px 15px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;color:var(--text-muted);font-size:13px;font-weight:600;"><i data-lucide="notebook-pen" style="width:14px;height:14px;"></i> 備忘錄<span id="memo-count" style="display:none;background:#ef4444;color:#fff;border-radius:99px;padding:1px 7px;font-size:10px;font-weight:800;"></span></button>
    <button onclick="openStats()" style="display:flex;align-items:center;gap:6px;padding:7px 15px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;color:var(--text-muted);font-size:13px;font-weight:600;"><i data-lucide="bar-chart-2" style="width:14px;height:14px;"></i> 全員血條</button>
