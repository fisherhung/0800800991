nd:none;cursor:pointer;color:var(--text-muted);border-bottom:2px solid transparent;">末期</button></div><div style="padding:16px 24px;border-bottom:1px solid var(--border);flex-shrink:0;"><div style="display:flex;gap:14px;align-items:center;"><div class="donut-wrap" style="flex-shrink:0;"><canvas id="donut-canvas" width="120" height="120"></canvas><div class="donut-center"><div id="donut-pct" style="font-size:22px;font-weight:900;color:var(--accent);line-height:1;">0%</div><div style="font-size:9px;color:var(--text-muted);font-weight:600;letter-spacing:.08em;">完工率</div></div></div><div style="flex:1;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;"><div style="padding:12px 14px;border-radius:14px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.18);text-align:center;"><div id="s-done" style="font-size:28px;font-weight:900;color:#10b981;line-height:1;">0</div><div style="font-size:10px;font-weight:700;color:#10b981;margin-top:4px;">已完工</div></div><div style="padding:12px 14px;border-radius:14px;background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.18);text-align:center;"><div id="s-claimed" style="font-size:28px;font-weight:900;color:#f59e0b;line-height:1;">0</div><div style="font-size:10px;font-weight:700;color:#f59e0b;margin-top:4px;">進行中</div></div><div style="padding:12px 14px;border-radius:14px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.18);text-align:center;"><div id="s-none" style="font-size:28px;font-weight:900;color:#ef4444;line-height:1;">0</div><div style="font-size:10px;font-weight:700;color:#ef4444;margin-top:4px;">未認領</div></div></div></div><div style="margin-top:14px;"><div style="display:flex;justify-content:space-between;margin-bottom:5px;"><span style="font-size:10px;font-weight:700;color:var(--text-muted);">OVERALL PROGRESS</span><span id="stats-total-label" style="font-size:10px;color:var(--text-muted);">0 個圖層</span></div><div style="height:8px;border-radius:99px;background:var(--border