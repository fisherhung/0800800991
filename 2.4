function scrollToCard(id){var asset=assets.get(id);if(!asset)return;var period=effectivePeriod(asset);var mm=getMonth(asset.name)||'??';var mmdd=getMMDD(asset.name)||'????';collapsedGroups.set('p:'+period,false);collapsedGroups.set('m:'+period+':'+mm,false);collapsedGroups.set('d:'+period+':'+mmdd,false);if(activePeriod!=='all'&&activePeriod!==period){activePeriod='all';document.querySelectorAll('.period-chip').forEach(function(c){c.classList.toggle('active',c.dataset.period==='all');});}renderList();requestAnimationFrame(function(){var card=document.getElementById('card-'+id);if(card){card.scrollIntoView({behavior:'smooth',block:'center'});card.classList.remove('flash');void card.offsetWidth;card.classList.add('flash');setTimeout(function(){card.classList.remove('flash');},1800);}});}
