      if(r.error)throw r.error;
      var url=sb.storage.from('kml-files').getPublicUrl(fname).data.publicUrl;
      var dname=file.name.replace(/\.(kml|kmz)$/i,'');
      return sb.from('kml_layers').insert({name:dname,color:'#94a3b8',visible:false,storage_path:fname,geojson_url:url}).select().single();
    }).then(function(res){
